# ============================================================
#  NGMI — environment config
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit the real .env (it's in .gitignore).
# ============================================================

# --- X (Twitter) OAuth 2.0 ----------------------------------
# Create an app at https://developer.x.com → Projects & Apps.
# In "User authentication settings":
#   • Type of App:        Web App (Confidential client)
#   • App permissions:    Read
#   • Callback URI:       http://localhost:5173/auth/x/callback   (must match EXACTLY)
#   • Website URL:        http://localhost:5173
# Then copy the OAuth 2.0 Client ID and Client Secret here.
X_CLIENT_ID=your_oauth2_client_id_here
X_CLIENT_SECRET=your_oauth2_client_secret_here

# Must byte-for-byte match the Callback URI registered on X above.
X_CALLBACK_URL=http://localhost:5173/auth/x/callback

# OAuth scopes (space separated). users.read + tweet.read is enough to read the handle.
X_SCOPES=users.read tweet.read

# --- NFT detection (optional, powers "select your NFTs" in the burn step) ---
# Alchemy API key — lets the burn step auto-detect the NFTs in a connected wallet.
# Free key at https://dashboard.alchemy.com (create an app, copy the API key).
# Leave blank to fall back to manual paste (contract address + token ID).
ALCHEMY_API_KEY=
INFURA_API_KEY=

# --- Server -------------------------------------------------
PORT=5173

# Long random string used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=7DHSJKS6ADADASUIJKSUIA
# Set to "true" only when serving over HTTPS in production (forces secure cookies).
COOKIE_SECURE=false

# Neon Postgres connection string (whitelist storage). Blank = local JSON file.
DATABASE_URL=

# Admin token for the /admin review page (any long random string)
ADMIN_TOKEN=
# Approx ETH→USD used for ATH scoring when ATH is given in ETH (default 3000)
ETH_USD_APPROX=
